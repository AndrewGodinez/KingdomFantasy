<?xml version="1.0" encoding="UTF-8"?>

<?import io.github.palexdev.materialfx.controls.MFXButton?>
<?import io.github.palexdev.materialfx.controls.MFXPasswordField?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane fx:id="root" minHeight="560.0" minWidth="780.0" prefHeight="600.0" prefWidth="980.0" styleClass="jfx-root-inputdevice" stylesheets="@../style/MainStyle.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="cr.ac.una.kingdomfantasy.controller.AjustesController">
    <top>
        <VBox alignment="CENTER" spacing="3.0" styleClass="jfx-bar-top">
            <padding>
                <Insets bottom="12.0" left="24.0" right="24.0" top="12.0" />
            </padding>
            <Label styleClass="jfx-title-badge" text="Configuración" />
            <Label styleClass="jfx-label-kicker" text="Selecciona el Control de Juego" />
        </VBox>
    </top>
    <center>
        <VBox alignment="TOP_CENTER" spacing="12.0">
            <padding>
                <Insets bottom="16.0" left="24.0" right="24.0" top="16.0" />
            </padding>
            <HBox spacing="14.0">
                <VBox fx:id="cardMouse" spacing="10.0" styleClass="jfx-card-control" HBox.hgrow="ALWAYS">
                    <padding>
                        <Insets bottom="14.0" left="14.0" right="14.0" top="14.0" />
                    </padding>
                    <HBox alignment="CENTER">
                        <ImageView fitHeight="90.0" fitWidth="120.0" pickOnBounds="true" preserveRatio="true">
                            <image>
                                <Image url="@../resource/Mouse-Icon.png" />
                            </image>
                        </ImageView>
                    </HBox>
                    <Label alignment="CENTER" maxWidth="1.7976931348623157E308" styleClass="jfx-label-upgrade-title" text="Mouse" />
                    <Label styleClass="jfx-label-upgrade-copy" text="Apunta con el cursor y haz clic para disparar." wrapText="true" />
                    <VBox spacing="6.0" VBox.vgrow="ALWAYS">
                        <HBox alignment="CENTER_LEFT" spacing="8.0">
                            <Label styleClass="jfx-chip-key" text="Click Izq." />
                            <Label maxWidth="1.7976931348623157E308" styleClass="jfx-label-key-action" text="Disparar flecha" wrapText="true" HBox.hgrow="ALWAYS" />
                        </HBox>
                        <HBox alignment="CENTER_LEFT" spacing="8.0">
                            <Label styleClass="jfx-chip-key" text="Mover Mouse" />
                            <Label maxWidth="1.7976931348623157E308" styleClass="jfx-label-key-action" text="Apuntar ballesta" wrapText="true" HBox.hgrow="ALWAYS" />
                        </HBox>
                    </VBox>
                    <MFXButton fx:id="btnMouse" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#onActionBtnMouse" styleClass="jfx-btn-primary" text="Usar Mouse" />
                </VBox>
                <VBox fx:id="cardKeyboard" spacing="10.0" styleClass="jfx-card-control" HBox.hgrow="ALWAYS">
                    <padding>
                        <Insets bottom="14.0" left="14.0" right="14.0" top="14.0" />
                    </padding>
                    <HBox alignment="CENTER">
                        <ImageView fitHeight="90.0" fitWidth="120.0" pickOnBounds="true" preserveRatio="true">
                            <image>
                                <Image url="@../resource/KeyBoard-Icon.png" />
                            </image>
                        </ImageView>
                    </HBox>
                    <Label alignment="CENTER" maxWidth="1.7976931348623157E308" styleClass="jfx-label-upgrade-title" text="Teclado" />
                    <Label styleClass="jfx-label-upgrade-copy" text="Usa las flechas para apuntar y la barra espaciadora para disparar." wrapText="true" />
                    <VBox spacing="6.0" VBox.vgrow="ALWAYS">
                        <HBox alignment="CENTER_LEFT" spacing="8.0">
                            <Label styleClass="jfx-chip-key" text="Espacio" />
                            <Label maxWidth="1.7976931348623157E308" styleClass="jfx-label-key-action" text="Disparar flecha" wrapText="true" HBox.hgrow="ALWAYS" />
                        </HBox>
                        <HBox alignment="CENTER_LEFT" spacing="8.0">
                            <Label styleClass="jfx-chip-key" text="Arriba / Abajo" />
                            <Label maxWidth="1.7976931348623157E308" styleClass="jfx-label-key-action" text="Apuntar ballesta" wrapText="true" HBox.hgrow="ALWAYS" />
                        </HBox>
                    </VBox>
                    <MFXButton fx:id="btnKeyboard" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#onActionBtnKeyboard" styleClass="jfx-btn-ghost" text="Usar Teclado" />
                </VBox>

            </HBox>
            <VBox fx:id="cardReview" spacing="10.0" styleClass="jfx-card-settings">
                <padding>
                    <Insets bottom="14.0" left="14.0" right="14.0" top="14.0" />
                </padding>

                <HBox alignment="CENTER_LEFT" spacing="14.0">
                    <ImageView fx:id="imvReviewIcon" fitHeight="70.0" fitWidth="94.0" pickOnBounds="true" preserveRatio="true">
                        <image>
                            <Image url="@../resource/Admin-Access-Icon.png" />
                        </image>
                    </ImageView>
                    <VBox alignment="CENTER_LEFT" spacing="3.0" HBox.hgrow="ALWAYS">
                        <Label styleClass="jfx-label-upgrade-title" text="Acceso avanzado" />
                        <Label styleClass="jfx-label-upgrade-copy" text="Ingresa la clave para habilitar las herramientas internas de revisión." wrapText="true" />
                    </VBox>
                </HBox>

                <HBox fx:id="reviewAccessBox" alignment="CENTER_LEFT" spacing="10.0">
                    <MFXPasswordField fx:id="txfReviewPassword" floatMode="BORDER" floatingText="Clave de acceso" maxWidth="260.0" styleClass="jfx-field-kingdom" HBox.hgrow="ALWAYS" />
                    <MFXButton fx:id="btnReviewUnlock" mnemonicParsing="false" onAction="#onActionBtnReviewUnlock" styleClass="jfx-btn-green" text="Desbloquear" />
                    <Label fx:id="lblReviewStatus" styleClass="jfx-label-selection-status" text="" HBox.hgrow="ALWAYS" />
                </HBox>

            </VBox>

        </VBox>
    </center>
    <bottom>
        <HBox alignment="CENTER_RIGHT" spacing="12.0" styleClass="jfx-bar-bottom">
            <padding>
                <Insets bottom="12.0" left="20.0" right="20.0" top="12.0" />
            </padding>
            <MFXButton fx:id="btnToggleAudio" mnemonicParsing="false" onAction="#onActionBtnToggleAudio" styleClass="jfx-btn-audio-toggle">
                <graphic>
                    <ImageView fx:id="imvAudioToggle" fitHeight="28.0" fitWidth="28.0" preserveRatio="true">
                        <image>
                            <Image url="@../resource/VolumeOn.png" />
                        </image>
                    </ImageView>
                </graphic>
            </MFXButton>
            <Label fx:id="lblMessage" maxWidth="1.7976931348623157E308" styleClass="jfx-label-status" text="" wrapText="true" HBox.hgrow="ALWAYS" />
            <MFXButton fx:id="btnInstructions" mnemonicParsing="false" onAction="#onActionBtnInstructions" styleClass="jfx-btn-ghost" text="Instrucciones" />
            <MFXButton fx:id="btnBackMenu" mnemonicParsing="false" onAction="#onActionBtnBackMenu" styleClass="jfx-btn-ghost" text="Volver" />
            <MFXButton fx:id="btnConfirm" mnemonicParsing="false" onAction="#onActionBtnBackMenu" styleClass="jfx-btn-green" text="Confirmar" />
        </HBox>
    </bottom>

</BorderPane>
