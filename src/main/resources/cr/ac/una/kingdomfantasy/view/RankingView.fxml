<?xml version="1.0" encoding="UTF-8"?>

<?import io.github.palexdev.materialfx.controls.MFXButton?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane fx:id="root" prefHeight="680.0" prefWidth="1100.0" styleClass="jfx-root-ranking" stylesheets="@../style/MainStyle.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="cr.ac.una.kingdomfantasy.controller.RankingController">

    <top>
        <VBox alignment="CENTER" spacing="14.0" styleClass="jfx-bar-top">
            <padding>
                <Insets bottom="18.0" left="24.0" right="24.0" top="18.0" />
            </padding>
            <Label styleClass="jfx-title-badge" text="RANKING GLOBAL" />
            <HBox alignment="CENTER" spacing="10.0">
                <MFXButton fx:id="btnPodium2" mnemonicParsing="false" onAction="#onActionPodium2" styleClass="jfx-btn-podium jfx-btn-podium-silver" text="2" />
                <MFXButton fx:id="btnPodium1" mnemonicParsing="false" onAction="#onActionPodium1" styleClass="jfx-btn-podium jfx-btn-podium-gold" text="1" />
                <MFXButton fx:id="btnPodium3" mnemonicParsing="false" onAction="#onActionPodium3" styleClass="jfx-btn-podium jfx-btn-podium-bronze" text="3" />
            </HBox>
        </VBox>
    </top>

    <center>
        <VBox>
            <VBox styleClass="jfx-panel-content" VBox.vgrow="ALWAYS">
                <VBox.margin>
                    <Insets bottom="0.0" left="24.0" right="24.0" top="16.0" />
                </VBox.margin>
            <children>
               <TableView fx:id="tblRanking" maxWidth="1.7976931348623157E308" prefHeight="200.0" prefWidth="200.0" styleClass="jfx-table-ranking" VBox.vgrow="ALWAYS">
                 <columns>
                   <TableColumn fx:id="colRank" prefWidth="86.0" text="#" />
                   <TableColumn fx:id="colAvatar" prefWidth="96.0" text="Avatar" />
                     <TableColumn fx:id="colName" prefWidth="360.0" text="Jugador" />
                     <TableColumn fx:id="colLevel" prefWidth="160.0" text="Nivel" />
                     <TableColumn fx:id="colPoints" prefWidth="190.0" text="Puntos" />
                 </columns>
                  <columnResizePolicy>
                     <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                  </columnResizePolicy>
               </TableView>
            </children>
            </VBox>

            <HBox alignment="CENTER_LEFT" spacing="20.0" styleClass="jfx-footer-player">
                <VBox.margin>
                    <Insets bottom="16.0" left="24.0" right="24.0" top="0.0" />
                </VBox.margin>
                <VBox alignment="CENTER" spacing="0.0" styleClass="jfx-footer-avatar-frame">
                    <Label styleClass="jfx-label-avatar-icon" text="👤" />
                </VBox>
                <VBox spacing="2.0">
                    <Label styleClass="jfx-label-footer-small" text="TU POSICIÓN" />
                    <Label fx:id="lblCurrentPlayerName" styleClass="jfx-label-footer-name" text="Jugador Actual" />
                </VBox>
                <Region HBox.hgrow="ALWAYS" />
                <VBox alignment="CENTER" spacing="2.0">
                    <Label styleClass="jfx-label-footer-stat" text="RANKING" />
                    <Label fx:id="lblCurrentPlayerRank" styleClass="jfx-label-footer-rank-value" text="#—" />
                </VBox>
                <VBox alignment="CENTER" spacing="2.0">
                    <Label styleClass="jfx-label-footer-stat" text="NIVEL" />
                    <Label fx:id="lblCurrentPlayerLevel" styleClass="jfx-label-footer-level-value" text="—" />
                </VBox>
                <VBox alignment="CENTER" spacing="2.0">
                    <Label styleClass="jfx-label-footer-stat" text="PUNTOS" />
                    <Label fx:id="lblCurrentPlayerPoints" styleClass="jfx-label-footer-points-value" text="—" />
                </VBox>
            </HBox>
        </VBox>
    </center>

    <bottom>
        <HBox alignment="CENTER_RIGHT" spacing="12.0" styleClass="jfx-bar-bottom">
            <padding>
                <Insets bottom="14.0" left="24.0" right="24.0" top="14.0" />
            </padding>
            <Region HBox.hgrow="ALWAYS" />
            <MFXButton fx:id="btnBack" mnemonicParsing="false" onAction="#onActionBack" styleClass="jfx-btn-ghost" text="← Volver al Menú" />
        </HBox>
    </bottom>

</BorderPane>
